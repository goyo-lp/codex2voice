# Optional fallback only. Preferred storage is macOS Keychain via `codex2voice init`.
# Do not commit real secrets.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Optional default voice id used by `codex2voice init` prompt default.
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here

# Optional debug logging (1 enables debug logs).
CODEX2VOICE_DEBUG=0

# Optional cache write debounce in milliseconds (0 disables debounce).
# Example: 120
CODEX2VOICE_CACHE_DEBOUNCE_MS=0

# Optional override for codex2voice state directory.
# Default is ~/.codex
# CODEX2VOICE_HOME=/absolute/path/to/custom/codex-home

# Optional override for voice-control skill fallback discovery when
# CODEX2VOICE_SESSION_CONTROL_FILE is not present.
# Default is ${TMPDIR:-/tmp}/codex2voice-session-control
# CODEX2VOICE_SESSION_CONTROL_DIR=/absolute/path/to/session-control-dir
